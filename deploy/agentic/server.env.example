# Copy to ~/.agentic-local/server.env and chmod 600.
AGENTIC_LLM_BASE_URL=http://127.0.0.1:52415/v1
AGENTIC_LLM_MODEL=mlx-community/Qwen3.6-35B-A3B-4bit
AGENTIC_TITLE_LLM_MODEL=mlx-community/Llama-3.2-1B-Instruct-4bit
AGENTIC_TITLE_LLM_TIMEOUT_S=10
# Internal URL opened by the admin/master "리소스 관리" button.
AGENTIC_CLUSTER_CONTROL_URL=http://127.0.0.1:52415

# Set these when publishing through a named Cloudflare Tunnel.
AGENTIC_PUBLIC_URL=https://agent.example.com
AGENTIC_ALLOWED_HOSTS=agent.example.com,127.0.0.1,localhost
AGENTIC_ALLOWED_SOURCE_ROOTS=/Users/dshs_llm/exo

# Keep public shell-based coding runs disabled.
AGENTIC_ALLOW_PUBLIC_RUNS=false

# Google OAuth Web application credentials.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://agent.example.com/auth/google/callback
