# Copy to scripts/cluster.env and adjust for the current wiring.
#
# Node1 remains the coordinator/API entrypoint.
# CONNECT_TYPE selects the SSH control path used by the helper scripts:
#   line = Thunderbolt Bridge / wired control path
#   net  = normal LAN/Wi-Fi control path

CONNECT_TYPE=line

MASTER_HOST=127.0.0.1
MASTER_NODE_NAME=node1
# Stable management-LAN address used for libp2p bootstrap even when line
# control is selected. This keeps discovery alive during a wired-link outage.
MASTER_NET_ADDRESS=10.80.119.202
# Thunderbolt Bridge address of node1 used when a worker is controlled over
# the line path.
MASTER_LINE_ADDRESS=10.0.0.1

# Thunderbolt Bridge control path.
WORKER1_LINE_HOST=node2@10.0.0.2
WORKER2_LINE_HOST=node3@10.0.0.3
WORKER3_LINE_HOST=node4@10.0.0.4

# Normal network fallback.
WORKER1_NET_HOST=node2@10.80.118.25
WORKER2_NET_HOST=node3@10.80.118.165
WORKER3_NET_HOST=node4@10.80.118.154

WORKER1_NODE_NAME=node2
WORKER2_NODE_NAME=node3
WORKER3_NODE_NAME=node4

NAMESPACE=macmini-rdma-llm
MODEL_ID=mlx-community/Qwen3.6-35B-A3B-4bit
MIN_NODES=4

REPO_DIR=/Users/dshs_llm/exo
MODELS_DIR=/Users/dshs_llm/models
API_HOST=127.0.0.1
API_PORT=52415
LIBP2P_PORT=52416

# A four-node star topology uses all nodes through pipeline placement.
# Tensor/MlxJaccl requires an RDMA cycle and is not valid for this wiring.
SHARDING=Pipeline
INSTANCE_META=MlxRing
FAST_SYNCH=true

# Optional request-level llama.cpp routing. Copy the example JSON, remove
# replicas whose GGUF server is not running, then enable it for the master.
# LLAMA_REPLICAS_FILE=/Users/dshs_llm/exo/scripts/llama-replicas.json
