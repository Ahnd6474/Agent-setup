# Copy to scripts/cluster.env and adjust for the current wiring.
#
# Node1 remains the coordinator/API entrypoint.
# CONNECT_TYPE selects the SSH control path used by the helper scripts:
#   line = Thunderbolt Bridge / wired control path
#   net  = normal LAN/Wi-Fi control path

CONNECT_TYPE=line

MASTER_HOST=127.0.0.1

# Thunderbolt Bridge control path.
WORKER1_LINE_HOST=node2@10.0.0.2
WORKER2_LINE_HOST=node3@Node3ui-Macmini.local
WORKER3_LINE_HOST=node4@10.0.0.4

# Normal network fallback.
WORKER1_NET_HOST=node2@10.80.118.25
WORKER2_NET_HOST=node3@10.80.118.165
WORKER3_NET_HOST=node4@10.80.118.154

NAMESPACE=macmini-rdma-llm
MODEL_ID=pipenetwork/MiniMax-M3-MLX-4bit
MIN_NODES=4

REPO_DIR=/Users/dshs_llm/exo
MODELS_DIR=/Users/dshs_llm/models
API_HOST=127.0.0.1
API_PORT=52415
LIBP2P_PORT=52416

# JACCL/RDMA path.
SHARDING=Tensor
INSTANCE_META=MlxJaccl
FAST_SYNCH=true
