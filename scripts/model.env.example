# Copy to scripts/model.env and adjust if you change the model.

MODEL_REPO=unsloth/Qwen3.6-35B-A3B-GGUF
MODEL_REVISION=main
MODEL_FILE=Qwen3.6-35B-A3B-Q8_0.gguf
MODEL_DIR=/Users/dshs_llm/llm-models/Qwen3.6-35B-A3B-GGUF

# Optional. Set this for gated/private Hugging Face repos.
# HF_TOKEN=hf_...

# aria2 tuning. Keep this conservative enough for Hugging Face.
ARIA2_CONNECTIONS=16
ARIA2_SPLIT=16
ARIA2_MIN_SPLIT_SIZE=16M

# Remote path used by sync_model_to_cluster.sh.
REMOTE_MODEL_DIR=~/llm-models/Qwen3.6-35B-A3B-GGUF

# Optional integrity check if a checksum is known.
# MODEL_SHA256=
